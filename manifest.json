{
  "manifest_version": 3,
  "name": "Auto YouTube Shorts Next",
  "version": "1.0",
  "description": "Automatically navigates to the next YouTube Short when the current one ends.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Shorts Next"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/shorts/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "scripting", "webNavigation"],
  "host_permissions": ["https://www.youtube.com/*"]
}
